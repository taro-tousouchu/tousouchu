<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KBC001 管理者認証システム</title>

<style>
body{
  margin:0;
  min-height:100vh;
  background:url("IMG_0599.jpeg") center center / cover no-repeat;
  color:white;
  font-family:sans-serif;
  text-align:center;
}

.box{
  padding-top:120px;
  width:90%;
  max-width:520px;
  margin:auto;
}

h1{
  color:red;
  font-size:48px;
  margin:0 0 10px;
}

h2{
  color:red;
  font-size:28px;
}

input{
  width:85%;
  padding:16px;
  font-size:24px;
  text-align:center;
  background:black;
  color:white;
  border:2px solid red;
  border-radius:10px;
}

button{
  margin-top:22px;
  padding:15px 55px;
  font-size:26px;
  background:black;
  color:red;
  border:2px solid red;
  border-radius:10px;
}

#result{
  margin-top:28px;
  font-size:26px;
  font-weight:bold;
}

#miss{
  margin-top:45px;
  font-size:20px;
}

#miss span{
  color:red;
  font-size:30px;
}

.notice{
  position:fixed;
  bottom:18px;
  left:5%;
  right:5%;
  padding:12px;
  color:red;
  border:1px solid #555;
  background:rgba(0,0,0,0.75);
  border-radius:8px;
}
</style>
</head>

<body>

<div class="box">
  <h1>KBC001</h1>
  <h2>管理者認証システム</h2>

  <p>管理者コードを入力せよ</p>

  <input id="code" type="password" placeholder="コードを入力">

  <br>

  <button onclick="checkCode()">認証</button>

  <div id="result">認証待機中...</div>

  <div id="miss">失敗回数：<span id="count">0</span> / 3</div>
</div>

<div class="notice">
  【注意】認証に3回失敗すると、不正アクセス検知が発動します。
</div>

<script>
let miss = 0;

function speak(text){
  speechSynthesis.cancel();

  const msg = new SpeechSynthesisUtterance(text);
  msg.lang = "ja-JP";
  msg.rate = 0.8;
  msg.pitch = 0.6;

  speechSynthesis.speak(msg);
}

function checkCode(){
  const code = document.getElementById("code").value;
  const result = document.getElementById("result");
  const count = document.getElementById("count");

  if(code === "KBC001"){
    result.style.color = "lime";
    result.innerHTML = "ACCESS GRANTED<br>管理者が変更されました";

    speak("管理者が変更されました");
  }else{
    miss++;
    count.innerHTML = miss;
    result.style.color = "red";

    if(miss >= 3){
      result.innerHTML = "🚨 不正アクセス検知 🚨";
      speak("不正アクセスを検知しました");
    }else{
      result.innerHTML = "認証失敗";
      speak("認証失敗");
    }
  }
}
</script>

</body>
</html>
